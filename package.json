{
  "name": "@solufy/evolution-go-sdk",
  "version": "0.1.0",
  "description": "Unofficial SDK for the Evolution GO Whatsapp API",
  "type": "module",
  "main": "./lib/src.cjs",
  "module": "./lib/src.mjs",
  "types": "./lib/src.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/src.d.mts",
        "default": "./lib/src.mjs"
      },
      "require": {
        "types": "./lib/src.d.cts",
        "default": "./lib/src.cjs"
      }
    }
  },
  "files": [
    "lib"
  ],
  "scripts": {
    "release": "pnpm build && changeset publish",
    "check-types": "tsc --noEmit",
    "build": "tsdown ./src",
    "lint": "biome check --write .",
    "lint:ci": "biome check .",
    "test": "vitest run"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "11.10.0",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@changesets/cli": "^2.31.1",
    "@rolldown/binding-darwin-arm64": "^1.2.0",
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.12",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "evolution",
    "api",
    "go",
    "whatsapp",
    "whatsmeow",
    "zap"
  ],
  "author": {
    "name": "João Gabriel Tonaco",
    "url": "https://github.com/joaotonaco"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/solufyapp/evolution-go-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/solufyapp/evolution-go-sdk/issues"
  },
  "homepage": "https://github.com/solufyapp/evolution-go-sdk#readme",
  "license": "MIT"
}
